# Client / VPS configuration — copy to client.env and fill in real values
# Never commit client.env to git (it's in .gitignore)

# ---- Required ----

# Short slug used in logs and naming
CLIENT_NAME="example-client"

# Absolute path to the working / project root on this VPS
# This is the directory where Claude Code primarily operates
CLAUDE_PROJECT_ROOT="/home/youruser/projects"

# Comma-separated absolute paths the Filesystem MCP is allowed to read/write
# Example: knowledge libraries, content drafts, brand books
KNOWLEDGE_LIBRARY_ROOTS="/home/youruser/projects,/home/youruser/knowledge"

# Where the Memory MCP stores its knowledge-graph JSON
# Persistent across sessions; back this up
MEMORY_STORE_PATH="/home/youruser/.agent-stack/memory.json"

# Where the Chroma vector store lives
# Contains embeddings of the knowledge library; back this up
CHROMA_DB_PATH="/home/youruser/.agent-stack/chroma_db"

# ---- agency-agents cherry-pick (script 07) ----

# Where the upstream msitarzewski/agency-agents repo gets cloned/cached on this VPS
AGENCY_AGENTS_CACHE_DIR="/home/youruser/.local/share/agency-agents"

# Where Claude Code looks for user-level sub-agents (~/.claude/agents/ for the agent user)
CLAUDE_AGENTS_DIR="/home/youruser/.claude/agents"

# Optional: JSON file with brand-voice-DNA paths to inject into voice-aware
# sub-agents (linkedin-content-creator, carousel-growth-engine,
# ai-citation-strategist, image-prompt-engineer, document-generator).
# Format: { "voice_dna_paths": [ "<absolute path>", ... ] }
# Leave empty to defer to user-level CLAUDE.md voice precedence instead.
BRAND_VOICE_PATHS_FILE=""

# ---- Optional (Tier 2 servers) ----

# Stripe — leave blank if not installing the Stripe MCP
# Use a RESTRICTED key (starts with rk_), never a full secret key (sk_)
STRIPE_RESTRICTED_KEY=""

# Cloudflare — leave blank if not installing the Cloudflare MCP
CLOUDFLARE_API_TOKEN=""

# Firecrawl — leave blank to skip Firecrawl MCP install (script 08 will skip gracefully).
# Get a key at https://firecrawl.dev/app/api-keys (free tier available).
FIRECRAWL_API_KEY=""

# Optional: where the agent reads MCP servers from at startup. If set, script 08
# edits this file directly (recommended for always-on agents — matches how the
# GHL MCP is registered). If unset, script 08 falls back to `claude mcp add`,
# which scopes to current working directory only and may not be visible to the
# agent if it starts from a different cwd.
# Example: "/opt/<your_tenant_user>/agents/.mcp.json"
AGENT_MCP_JSON_PATH=""

# Notion — leave blank if not installing the Notion MCP
NOTION_INTEGRATION_TOKEN=""

# ---- Optional embedding provider for Chroma ----

# If using a hosted embedding provider, set the key here
# Otherwise Chroma will use its default local embedding model (slower, no external dependency)
OPENAI_API_KEY_FOR_EMBEDDINGS=""

# ---- Logging ----

# Where install.log gets written
INSTALL_LOG_PATH="/home/youruser/agent-stack/install.log"
