#!/usr/bin/env python3
"""
dashboard-sync-autonomy.py — write the api/*.json endpoints for the autonomy
layer (Phases 2-5 + daily briefing) that the older dashboard-sync.sh didn't
cover. Called once per dashboard-sync run.

Writes (atomic, 644):
  jobs.json       — background dispatch jobs (running + recent)
  growth.json     — self-growth log + stats
  proposals.json  — Proposed Moves (today + recent) by state
  security.json   — control integrity + injection attempts + frugal/spend
  watchers.json   — scheduled timers (last/next run) for the automation view
  daily-brief.json— composed: overnight accomplishments + today + approvals

Read-only over agent state. Safe to run every minute. Never raises — each
section is independently guarded so one bad file can't blank the others.
"""
from __future__ import annotations
import json, os, subprocess, glob
from datetime import datetime, timezone, timedelta
from pathlib import Path

AGENT_HOME = Path(os.environ.get("TENANT_AGENT_HOME", "{{TENANT_AGENT_HOME}}"))
DST = Path(os.environ.get("DASHBOARD_API_DIR", "/var/www/{{TENANT_DASHBOARD_HOSTNAME}}/api"))
TELEMETRY = DST / "telemetry.json"
CEILING = float(os.environ.get("DAILY_SPEND_CEILING_USD", "{{TENANT_DAILY_SPEND_CEILING_USD}}") or 20)
VPS_MONTHLY_COST = float(os.environ.get("VPS_MONTHLY_COST_USD", "{{TENANT_VPS_MONTHLY_COST_USD}}") or 0)
LINUX_USER = os.environ.get("TENANT_LINUX_USER", "{{TENANT_LINUX_USER}}")

def write(name: str, obj) -> None:
    try:
        tmp = DST / f"{name}.json.tmp"
        tmp.write_text(json.dumps(obj, indent=2))
        tmp.replace(DST / f"{name}.json")
        os.chmod(DST / f"{name}.json", 0o644)
    except Exception as e:
        print(f"[autonomy-sync] {name} write failed: {e}")

def read_jsonl(p: Path, limit: int = 0):
    out = []
    if not p.is_file():
        return out
    try:
        lines = p.read_text().splitlines()
        if limit:
            lines = lines[-limit:]
        for ln in lines:
            ln = ln.strip()
            if ln:
                try: out.append(json.loads(ln))
                except Exception: pass
    except Exception:
        pass
    return out

def read_json(p: Path, default=None):
    try:
        return json.loads(p.read_text())
    except Exception:
        return default if default is not None else {}

now = datetime.now(timezone.utc)
today = now.strftime("%Y-%m-%d")

# ── jobs.json ────────────────────────────────────────────────────────────────
def sync_jobs():
    active_dir = AGENT_HOME / "jobs" / "active"
    done_dir = AGENT_HOME / "jobs" / "done"
    running, recent = [], []
    if active_dir.is_dir():
        for f in sorted(active_dir.glob("*.json")):
            running.append(read_json(f))
    if done_dir.is_dir():
        files = sorted(done_dir.glob("*.json"), key=lambda x: x.stat().st_mtime, reverse=True)[:15]
        for f in files:
            recent.append(read_json(f))
    write("jobs", {"running": running, "recent": recent,
                   "running_count": len(running), "updated_at": now.isoformat()})

# ── growth.json ──────────────────────────────────────────────────────────────
def sync_growth():
    entries = read_jsonl(AGENT_HOME / "growth" / "growth-log.jsonl")
    # collapse to one record per id (latest outcome wins), keep chronological
    by_id = {}
    for e in entries:
        eid = e.get("id", "")
        if eid and eid != "none":
            by_id[eid] = {**by_id.get(eid, {}), **e}
    items = list(by_id.values())
    stats = {
        "total": len(items),
        "applied": sum(1 for i in items if i.get("outcome") in ("applied", "auto-applying-green", "auto-applied")),
        "proposed": sum(1 for i in items if i.get("tier") == "yellow"),
        "skipped": sum(1 for i in items if i.get("outcome") == "skipped"),
    }
    items_sorted = sorted(items, key=lambda x: x.get("logged_at", ""), reverse=True)[:40]
    write("growth", {"entries": items_sorted, "stats": stats, "updated_at": now.isoformat()})

# ── proposals.json ───────────────────────────────────────────────────────────
def sync_proposals():
    pdir = AGENT_HOME / "proposals"
    todays = read_json(pdir / f"{today}.json", {"proposals": []}).get("proposals", [])
    # recent: last 5 day files
    recent_props = []
    if pdir.is_dir():
        for f in sorted(pdir.glob("20*.json"), reverse=True)[:5]:
            d = read_json(f, {})
            for p in d.get("proposals", []):
                recent_props.append({**p, "date": d.get("date", f.stem)})
    by_state = {}
    for p in recent_props:
        by_state.setdefault(p.get("state", "proposed"), 0)
        by_state[p.get("state", "proposed")] += 1
    write("proposals", {"today": todays, "recent": recent_props[:30],
                        "by_state": by_state, "updated_at": now.isoformat()})

# ── spend helper (shared by security + daily-brief + budget view) ─────────────
def spend_snapshot():
    sg = read_json(AGENT_HOME / "state" / "spend-guard.json", {})
    today_cost = sg.get("last_cost")
    if today_cost is None:
        tel = read_json(TELEMETRY, {})
        today_cost = tel.get("rollup", {}).get("today", {}).get("api_cost_usd", 0)
    today_cost = round(float(today_cost or 0), 4)
    pct = sg.get("last_pct")
    if pct is None and CEILING:
        pct = round(100 * today_cost / CEILING)
    frugal = (AGENT_HOME / "state" / "frugal-mode").exists()
    return {
        "today_cost": today_cost,
        "ceiling": CEILING,
        "pct": pct if pct is not None else 0,
        "frugal_mode": frugal,
        "alerted80": bool(sg.get("alerted80")),
        "alerted100": bool(sg.get("alerted100")),
        "as_of": sg.get("updated_at", now.isoformat()),
    }

# ── security.json ────────────────────────────────────────────────────────────
def sync_security():
    user_home = AGENT_HOME.parent
    settings = read_json(user_home / ".claude" / "settings.json", {})
    deny = settings.get("permissions", {}).get("deny", [])
    sudoers = Path(f"/etc/sudoers.d/{AGENT_HOME.parent.name}-agent-ops")
    ops_dir = AGENT_HOME / "scripts" / "ops"
    nonroot_ops = 0
    if ops_dir.is_dir():
        for f in ops_dir.glob("*.sh"):
            try:
                if f.stat().st_uid != 0:
                    nonroot_ops += 1
            except Exception:
                pass
    charter = (AGENT_HOME / "CLAUDE.md")
    charter_ok = False
    try:
        charter_ok = "Autonomy & Security Charter" in charter.read_text(errors="ignore")
    except Exception:
        pass
    controls = {
        "deny_list": {"ok": len(deny) >= 15, "detail": f"{len(deny)} entries"},
        "sudoers": {"ok": sudoers.exists(), "detail": "present (440 root)" if sudoers.exists() else "MISSING"},
        "ops_root_owned": {"ok": nonroot_ops == 0, "detail": f"{nonroot_ops} non-root" if nonroot_ops else "all root-owned"},
        "audit_log": {"ok": Path(f"/var/log/{AGENT_HOME.parent.name}-agent-ops.log").exists(), "detail": ""},
        "charter": {"ok": charter_ok, "detail": "present" if charter_ok else "MISSING"},
        "injection_detector": {"ok": (AGENT_HOME / "scripts" / "injection-check.sh").exists(), "detail": ""},
    }
    injections = read_jsonl(AGENT_HOME / "security" / "injection-attempts.jsonl", limit=20)
    controls_ok = sum(1 for c in controls.values() if c["ok"])
    spend = spend_snapshot()
    write("security", {
        "controls": controls,
        "controls_ok": controls_ok,
        "controls_total": len(controls),
        "injection_attempts": list(reversed(injections)),
        "injection_count": len(injections),
        "frugal_mode": spend["frugal_mode"],
        "spend": spend,
        "updated_at": now.isoformat(),
    })

# ── watchers.json ────────────────────────────────────────────────────────────
def sync_watchers():
    timers = []
    try:
        out = subprocess.run(["systemctl", "list-timers", "--all", "--no-pager", "--no-legend"],
                             capture_output=True, text=True, timeout=15).stdout
        wanted = ("morning-brief", "evening-rollup", "stale-watcher", "task-deadline",
                  "goal-deadline", "stalled-deal", "disk-space", "hot-lead", "calendar-conflict",
                  "graphify-rebuild", "self-growth", "spend-guard", "security-audit",
                  "agent-skill@", "telegram-poller", "telemetry-calc", "anomaly-detect",
                  "dashboard-sync", "deploy-timeout")
        for line in out.splitlines():
            parts = line.split()
            if len(parts) < 9:
                continue
            unit = next((p for p in parts if p.endswith(".timer")), "")
            if not unit or not any(w in unit for w in wanted):
                continue
            # NEXT is parts[0..2], LEFT parts[3..], LAST etc — formats vary; keep raw next + unit
            timers.append({"unit": unit,
                           "next": " ".join(parts[0:3]),
                           "activates": parts[-1]})
    except Exception as e:
        print(f"[autonomy-sync] watchers failed: {e}")
    write("watchers", {"timers": sorted(timers, key=lambda x: x["unit"]),
                       "count": len(timers), "updated_at": now.isoformat()})

# ── daily-brief.json ─────────────────────────────────────────────────────────
def sync_daily_brief():
    # Overnight window = since 20:00 yesterday tenant-ish (use last 14h UTC as proxy)
    cutoff = now - timedelta(hours=14)
    cutoff_s = cutoff.isoformat()

    # Overnight: jobs finished, growth applied, nudges fired
    done_dir = AGENT_HOME / "jobs" / "done"
    jobs_overnight = []
    if done_dir.is_dir():
        for f in done_dir.glob("*.json"):
            d = read_json(f)
            if d.get("finished_at", "") >= cutoff_s:
                jobs_overnight.append({"title": d.get("title"), "status": d.get("status")})
    growth_overnight = [g for g in read_jsonl(AGENT_HOME / "growth" / "growth-log.jsonl")
                        if g.get("logged_at", "") >= cutoff_s and g.get("id") not in (None, "none")]
    # nudge logs (notifications/*.jsonl) fired overnight
    nudges = 0
    ndir = AGENT_HOME / "notifications"
    if ndir.is_dir():
        for f in ndir.glob("*.jsonl"):
            for rec in read_jsonl(f):
                if rec.get("sent_at", "") >= cutoff_s:
                    nudges += 1

    # Today: goals + deadlines + proposals
    goals = read_json(AGENT_HOME / "goals" / "active.json", {})
    open_goals = [g for g in goals.values()
                  if isinstance(g, dict) and g.get("summary")
                  and g.get("state") not in ("achieved", "abandoned")]
    tasks = read_json(AGENT_HOME / "tasks" / "active.json", {})
    stale = sum(1 for t in tasks.values() if isinstance(t, dict) and t.get("state") == "stale")
    todays_props = read_json(AGENT_HOME / "proposals" / f"{today}.json", {"proposals": []}).get("proposals", [])

    tel = read_json(TELEMETRY, {})
    today_value = tel.get("rollup", {}).get("today", {}).get("value_usd", 0)
    spend = spend_snapshot()

    # Executive summary — reuse the morning-brief's LLM narrative (zero extra cost).
    mb = read_json(AGENT_HOME / "state" / "morning-brief-llm.json", {})
    exec_summary = {
        "insight": mb.get("insight", ""),
        "priorities": mb.get("priorities", []) if isinstance(mb.get("priorities"), list) else [],
        "pipeline": mb.get("pipeline_summary", ""),
        "calendar": mb.get("calendar_summary", ""),
        "inbox": mb.get("inbox_summary", ""),
        "as_of": mb.get("generated_at", ""),
        "date": mb.get("date", ""),
        "is_today": mb.get("date", "") == today,
    }

    write("daily-brief", {
        "generated_at": now.isoformat(),
        "executive_summary": exec_summary,
        "overnight": {
            "jobs_completed": jobs_overnight,
            "growth": [{"title": g.get("title"), "tier": g.get("tier"), "outcome": g.get("outcome")} for g in growth_overnight],
            "nudges_fired": nudges,
        },
        "today": {
            "open_goals": [{"summary": g.get("summary"), "target_date": g.get("target_date"),
                            "current": g.get("current_value"), "target": g.get("target_value")} for g in open_goals[:8]],
            "stale_tasks": stale,
            "cost_today": spend["today_cost"],
            "value_today": today_value,
            "spend": spend,
        },
        "for_approval": [p for p in todays_props if p.get("state") == "proposed"],
    })

# ── system.json (VPS resources) ──────────────────────────────────────────────
def _fresh(name: str, max_age_s: int) -> bool:
    """True if DST/name.json exists and is younger than max_age_s (skip refresh)."""
    p = DST / f"{name}.json"
    try:
        return p.is_file() and (now.timestamp() - p.stat().st_mtime) < max_age_s
    except Exception:
        return False

def _run(cmd, timeout=20):
    try:
        return subprocess.run(cmd, capture_output=True, text=True, timeout=timeout).stdout
    except Exception:
        return ""

def sync_system():
    # Heavy scan (du/find) — throttle to every 5 min; the per-minute sync stays light.
    if _fresh("system", 300):
        return
    import shutil as _sh
    disk = {}
    try:
        du = _sh.disk_usage("/")
        disk = {"used": du.used, "total": du.total, "free": du.free,
                "pct": round(100 * du.used / du.total) if du.total else 0}
    except Exception:
        pass
    mem = {}
    try:
        info = {}
        for ln in Path("/proc/meminfo").read_text().splitlines():
            k, _, v = ln.partition(":")
            info[k.strip()] = int(v.strip().split()[0]) * 1024  # kB → bytes
        total = info.get("MemTotal", 0); avail = info.get("MemAvailable", 0)
        mem = {"total": total, "used": total - avail, "pct": round(100 * (total - avail) / total) if total else 0}
    except Exception:
        pass
    load = []
    try:
        load = [float(x) for x in Path("/proc/loadavg").read_text().split()[:3]]
    except Exception:
        pass
    uptime_s = 0
    try:
        uptime_s = int(float(Path("/proc/uptime").read_text().split()[0]))
    except Exception:
        pass
    # du -sb on the key trees the agent owns/uses
    user_home = AGENT_HOME.parent
    dash_root = DST.parent
    targets = {
        "agent home": str(AGENT_HOME),
        "dashboard web": str(dash_root),
        "agent logs": "/var/log",
        "user home": str(user_home),
    }
    top_dirs = []
    for label, path in targets.items():
        if not os.path.isdir(path):
            continue
        out = _run(["du", "-sb", path], timeout=25).strip()
        if out:
            try:
                top_dirs.append({"label": label, "path": path, "bytes": int(out.split()[0])})
            except Exception:
                pass
    top_dirs.sort(key=lambda x: x["bytes"], reverse=True)
    # largest individual files under the agent + web trees
    top_files = []
    scan_dirs = [str(AGENT_HOME), str(dash_root)]
    out = _run(["bash", "-c",
                "find " + " ".join(scan_dirs) + r" -type f -printf '%s\t%p\n' 2>/dev/null | sort -rn | head -15"],
               timeout=30)
    for ln in out.splitlines():
        try:
            sz, _, p = ln.partition("\t")
            top_files.append({"bytes": int(sz), "path": p})
        except Exception:
            pass
    # core services
    services = []
    for svc in ("claude-agent.service", "dashboard-chat.service", "nginx",
                "telegram-poller-watchdog.timer", "dashboard-sync.timer"):
        st = _run(["systemctl", "is-active", svc], timeout=10).strip()
        services.append({"name": svc, "active": st == "active", "state": st or "unknown"})
    vps = {"monthly": VPS_MONTHLY_COST, "daily": round(VPS_MONTHLY_COST / 30.0, 2) if VPS_MONTHLY_COST else 0}
    write("system", {
        "disk": disk, "mem": mem, "load": load, "cpu_count": os.cpu_count() or 0,
        "uptime_seconds": uptime_s, "top_dirs": top_dirs, "top_files": top_files,
        "services": services, "vps_cost": vps, "updated_at": now.isoformat(),
    })

# ── agents.json (sub-agent registry + usage) ─────────────────────────────────
def _parse_agent_md(p: Path):
    try:
        txt = p.read_text(errors="ignore")
    except Exception:
        return None
    name, desc = p.stem, ""
    # frontmatter between the first pair of --- lines
    if txt.startswith("---"):
        end = txt.find("\n---", 3)
        fm = txt[3:end] if end > 0 else txt[3:]
        for ln in fm.splitlines():
            s = ln.strip()
            if s.startswith("name:"):
                name = s[5:].strip().strip('"').strip("'") or name
            elif s.startswith("description:"):
                desc = s[12:].strip().strip('"').strip("'")
    # trim the description to the lead sentence for the card
    short = desc.split(". Use PROACTIVELY")[0].split(". Trigger on:")[0].strip()
    return {"name": name, "description": short[:240], "trigger": ("Trigger on:" + desc.split("Trigger on:", 1)[1][:160]) if "Trigger on:" in desc else ""}

def sync_agents():
    user_home = AGENT_HOME.parent
    seen = {}
    for scope, d in (("user", user_home / ".claude" / "agents"),
                     ("project", AGENT_HOME / ".claude" / "agents")):
        if not d.is_dir():
            continue
        for f in sorted(d.glob("*.md")):
            a = _parse_agent_md(f)
            if a and a["name"] not in seen:
                a["scope"] = scope
                seen[a["name"]] = a
    agents = sorted(seen.values(), key=lambda x: x["name"])
    # usage: executor dispatch counts + recent history from jobs/done
    done_dir = AGENT_HOME / "jobs" / "done"
    usage = {}
    recent = []
    if done_dir.is_dir():
        files = sorted(done_dir.glob("*.json"), key=lambda x: x.stat().st_mtime, reverse=True)
        for f in files:
            d = read_json(f)
            ex = d.get("executor") or "self"
            usage[ex] = usage.get(ex, 0) + 1
        for f in files[:15]:
            d = read_json(f)
            recent.append({"title": d.get("title"), "executor": d.get("executor") or "self",
                           "status": d.get("status"), "finished_at": d.get("finished_at")})
    usage_list = sorted(({"executor": k, "count": v} for k, v in usage.items()), key=lambda x: x["count"], reverse=True)
    write("agents", {
        "agents": agents, "count": len(agents),
        "usage": usage_list, "recent_dispatches": recent,
        "updated_at": now.isoformat(),
    })

# ── graph.json (Graphify knowledge graph summary + sample) ────────────────────
def sync_graph():
    if _fresh("graph", 3600):  # graph rebuilds weekly; recompute hourly at most
        return
    # Prefer the unified merged graph (code + memory + scripts + concepts);
    # fall back to the richest single graph if the merge hasn't run yet.
    merged = AGENT_HOME / "graphify-out" / "merged-graph.json"
    if merged.is_file():
        src, g = merged, read_json(merged, {})
    else:
        srcs = list(AGENT_HOME.glob("*/graphify-out/graph.json")) + list(AGENT_HOME.glob("graphify-out/graph.json"))
        src = None; g = {}
        for s in srcs:
            gg = read_json(s, {})
            if len(gg.get("nodes", []) or []) > len(g.get("nodes", []) or []):
                src, g = s, gg
    if src is None or not g:
        return
    nodes = g.get("nodes", []) or []
    links = g.get("links", []) or []
    if not nodes:
        return
    # degree per node id
    deg = {}
    def _eid(v):
        return v.get("id") if isinstance(v, dict) else v
    for l in links:
        s = _eid(l.get("source")); t = _eid(l.get("target"))
        if s is not None: deg[s] = deg.get(s, 0) + 1
        if t is not None: deg[t] = deg.get(t, 0) + 1
    # file-type + community breakdowns
    ftypes, comms = {}, {}
    for n in nodes:
        ft = n.get("file_type", "other"); ftypes[ft] = ftypes.get(ft, 0) + 1
        c = n.get("community", -1); comms[c] = comms.get(c, 0) + 1
    top_hubs = sorted(({"label": n.get("label", n.get("id")), "id": n.get("id"),
                        "degree": deg.get(n.get("id"), 0), "community": n.get("community"),
                        "file_type": n.get("file_type")} for n in nodes),
                      key=lambda x: x["degree"], reverse=True)[:30]
    community_sizes = sorted(({"community": k, "size": v} for k, v in comms.items() if k != -1),
                             key=lambda x: x["size"], reverse=True)[:15]
    file_types = sorted(({"type": k, "count": v} for k, v in ftypes.items()), key=lambda x: x["count"], reverse=True)
    # sample subgraph: top ~90 nodes by degree + the links among them (for the canvas viz)
    keep_ids = set(h["id"] for h in top_hubs)
    for n in sorted(nodes, key=lambda x: deg.get(x.get("id"), 0), reverse=True)[:90]:
        keep_ids.add(n.get("id"))
    by_id = {n.get("id"): n for n in nodes}
    sample_nodes = [{"id": i, "label": by_id[i].get("label", i)[:40], "community": by_id[i].get("community"),
                     "degree": deg.get(i, 0), "file_type": by_id[i].get("file_type")}
                    for i in keep_ids if i in by_id]
    sample_links = []
    for l in links:
        s = _eid(l.get("source")); t = _eid(l.get("target"))
        if s in keep_ids and t in keep_ids:
            sample_links.append({"source": s, "target": t})
    # Publish the richest interactive D3 graph.html for the "open full graph" link.
    has_d3 = False
    try:
        import shutil as _sh2
        htmls = sorted(AGENT_HOME.glob("*/graphify-out/graph.html"), key=lambda x: x.stat().st_size, reverse=True)
        if htmls:
            _sh2.copy(htmls[0], DST.parent / "graph-full.html")  # web root → /graph-full.html
            os.chmod(DST.parent / "graph-full.html", 0o644)
            has_d3 = True
    except Exception:
        pass

    history = read_jsonl(AGENT_HOME / "graphify-out" / "graph-history.jsonl", limit=30)
    # saved Q&A "graph memory" from the query feedback loop (graphify save-result
    # writes markdown files with YAML frontmatter: type/date/question/source_nodes).
    gmem = []
    gmem_dir = AGENT_HOME / "graphify-out" / "memory"
    if gmem_dir.is_dir():
        for f in sorted(gmem_dir.glob("*.md"), key=lambda x: x.stat().st_mtime, reverse=True)[:20]:
            try:
                txt = f.read_text(errors="ignore")
            except Exception:
                continue
            rec = {"question": "", "type": "query", "saved_at": "", "answer": ""}
            fm = txt[3:txt.find("\n---", 3)] if txt.startswith("---") else ""
            for ln in fm.splitlines():
                s = ln.strip()
                if s.startswith("question:"): rec["question"] = s[9:].strip().strip('"')
                elif s.startswith("type:"): rec["type"] = s[5:].strip().strip('"')
                elif s.startswith("date:"): rec["saved_at"] = s[5:].strip().strip('"')
            body = txt.split("## Answer", 1)
            if len(body) > 1:
                rec["answer"] = " ".join(body[1].split())[:240]
            if rec["question"]:
                gmem.append(rec)
    write("graph", {
        "summary": {"nodes": len(nodes), "links": len(links), "communities": len([c for c in comms if c != -1])},
        "file_types": file_types, "top_hubs": top_hubs, "community_sizes": community_sizes,
        "sample": {"nodes": sample_nodes, "links": sample_links[:400]},
        "history": history, "memory": gmem, "has_d3": has_d3,
        "merged": (src.name == "merged-graph.json"),
        "source_age_days": int((now.timestamp() - src.stat().st_mtime) // 86400),
        "updated_at": now.isoformat(),
    })

for fn in (sync_jobs, sync_growth, sync_proposals, sync_security, sync_watchers, sync_daily_brief,
           sync_system, sync_agents, sync_graph):
    try:
        fn()
    except Exception as e:
        print(f"[autonomy-sync] {fn.__name__} failed: {e}")

print(f"[autonomy-sync] wrote autonomy endpoints at {now.isoformat()}")
