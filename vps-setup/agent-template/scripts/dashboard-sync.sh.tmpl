# v2.54.0+: /api/spans.json — OTel span store with live span, cache attribution, latency.
python3 << 'PY' > "$DST/spans.json.tmp"
import json
import sys
from datetime import datetime, timezone, timedelta
sys.path.insert(0, "{{TENANT_AGENT_HOME}}/scripts")
import _spans

NOW = datetime.now(timezone.utc)
try:
    with _spans.connect() as conn:
        recent = _spans.recent_spans(conn, limit=200)
        since_24h = _spans.iso_minus_hours(24)
        tools = _spans.tool_breakdown(conn, since_24h)
        kinds = _spans.kind_breakdown(conn, since_24h)
        agents = _spans.agent_breakdown(conn, since_24h)  # v2.70.0 per-sub-agent
        since_live = (NOW - timedelta(minutes=3)).isoformat().replace("+00:00", "Z")
        live = _spans.live_span(conn, since_live)
        latencies = _spans.session_latencies(conn, since_24h)
        total_24h  = sum(k.get("calls", 0) for k in kinds)
        tokens_24h = sum(k.get("tokens_total", 0) or 0 for k in kinds)
        recent_24h = [r for r in recent if r.get("start_ts", "") >= since_24h]
        cost_24h   = round(sum((r.get("cost_usd") or 0) for r in recent_24h), 4)
        cache_read_24h  = sum(r.get("cache_read", 0)  for r in recent_24h)
        cache_write_24h = sum(r.get("cache_write", 0) for r in recent_24h)
        input_24h       = sum(r.get("tokens_in", 0)   for r in recent_24h)
        cache_input_total = cache_read_24h + input_24h
        cache_ratio_24h = round(cache_read_24h / cache_input_total, 4) if cache_input_total > 0 else 0.0
        cache_savings_24h = round((cache_read_24h / 1_000_000) * (3.00 - 0.30), 4)
except Exception:
    recent, tools, kinds, live, agents = [], [], [], None, []
    total_24h, tokens_24h, cost_24h = 0, 0, 0.0
    cache_ratio_24h = cache_savings_24h = 0.0
    cache_read_24h = cache_write_24h = 0
    latencies = {"sessions": [], "summary": {
        "sessions": 0, "median_first_action_ms": None, "p95_first_action_ms": None,
        "median_total_ms": None, "p95_total_ms": None,
    }}

print(json.dumps({
    "generated_at": NOW.isoformat().replace("+00:00", "Z"),
    "recent": recent, "tools": tools, "kinds":  kinds, "agents": agents, "live":   live,
    "summary": {
        "calls_24h":         total_24h,
        "tokens_24h":        tokens_24h,
        "cost_usd_24h":      cost_24h,
        "cache_read_24h":    cache_read_24h,
        "cache_write_24h":   cache_write_24h,
        "cache_ratio_24h":   cache_ratio_24h,
        "cache_savings_24h": cache_savings_24h,
    },
    "latency": latencies["summary"],
    "latency_sessions": latencies["sessions"][:25],
}, indent=2, default=str))
PY
