[Unit]
Description=Telemetry anomaly detection — rolling z-scores + EWMA over daily_token_history
After=network.target telemetry-calc.service
Wants=network.target

[Service]
Type=oneshot
User={{TENANT_LINUX_USER}}
Group={{TENANT_LINUX_GROUP}}
WorkingDirectory={{TENANT_AGENT_HOME}}
Environment="HOME={{TENANT_USER_HOME}}"
Environment="PATH=/usr/local/bin:/usr/bin:/bin:{{TENANT_USER_HOME}}/.local/bin"
ExecStart=/usr/bin/python3 {{TENANT_AGENT_HOME}}/scripts/anomaly-detect.py
StandardOutput=append:{{TENANT_AGENT_HOME}}/logs/anomaly-detect.log
StandardError=append:{{TENANT_AGENT_HOME}}/logs/anomaly-detect.log
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
