[Unit]
Description={{TENANT_PERSON_FULL_NAME}} scheduled agent skill — %i
Documentation=https://github.com/{{TENANT_BRAND_REPO_GH_PATH}}
After=network.target claude-agent.service

[Service]
Type=oneshot
User={{TENANT_LINUX_USER}}
Group={{TENANT_LINUX_GROUP}}
WorkingDirectory={{TENANT_AGENT_HOME}}
Environment="HOME={{TENANT_USER_HOME}}"
Environment="PATH=/usr/local/bin:/usr/bin:/bin:{{TENANT_USER_HOME}}/.bun/bin:{{TENANT_USER_HOME}}/.local/bin"
ExecStart={{TENANT_AGENT_HOME}}/scripts/skill-runner.sh %i
StandardOutput=append:{{TENANT_AGENT_HOME}}/logs/agent-skill-systemd.log
StandardError=append:{{TENANT_AGENT_HOME}}/logs/agent-skill-systemd.log
TimeoutStartSec=600
