[Unit]
Description={{TENANT_PERSON_FIRST_NAME}} Gonell spend guard (daily LLM ceiling + frugal-mode throttle)
Documentation=https://github.com/newmindsgroup/{{TENANT_BRAND_REPO_NAME}}
After=network.target

[Service]
Type=oneshot
User={{TENANT_LINUX_USER}}
Group={{TENANT_LINUX_GROUP}}
WorkingDirectory={{TENANT_AGENT_HOME}}
Environment="HOME={{TENANT_USER_HOME}}"
Environment="PATH=/usr/local/bin:/usr/bin:/bin:{{TENANT_USER_HOME}}/.bun/bin:{{TENANT_USER_HOME}}/.local/bin"
Environment="TENANT_AGENT_HOME={{TENANT_AGENT_HOME}}"
ExecStart={{TENANT_AGENT_HOME}}/scripts/spend-guard.sh
StandardOutput=append:{{TENANT_AGENT_HOME}}/logs/spend-guard-systemd.log
StandardError=append:{{TENANT_AGENT_HOME}}/logs/spend-guard-systemd.log
TimeoutStartSec=60
