[Unit]
Description=Cost-attribution report — today's spend by kind/session + cache ratio
After=network.target telemetry-calc.service session-parser.service
Wants=network.target

[Service]
Type=oneshot
User={{TENANT_LINUX_USER}}
Group={{TENANT_LINUX_GROUP}}
WorkingDirectory={{TENANT_AGENT_HOME}}
Environment="HOME={{TENANT_USER_HOME}}"
Environment="PATH=/usr/local/bin:/usr/bin:/bin:{{TENANT_USER_HOME}}/.local/bin"
ExecStart=/usr/bin/python3 {{TENANT_AGENT_HOME}}/scripts/cost-report.py
StandardOutput=append:{{TENANT_AGENT_HOME}}/logs/cost-report.log
StandardError=append:{{TENANT_AGENT_HOME}}/logs/cost-report.log
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
