[Unit]
Description={{TENANT_PERSON_FULL_NAME}} evening rollup — end-of-day Telegram brief
After=network.target claude-agent.service

[Service]
Type=oneshot
User={{TENANT_LINUX_USER}}
Group={{TENANT_LINUX_GROUP}}
WorkingDirectory={{TENANT_AGENT_HOME}}
Environment="HOME={{TENANT_USER_HOME}}"
Environment="PATH=/usr/local/bin:/usr/bin:/bin:{{TENANT_USER_HOME}}/.bun/bin:{{TENANT_USER_HOME}}/.local/bin"
ExecStart={{TENANT_AGENT_HOME}}/scripts/evening-rollup.sh
StandardOutput=append:{{TENANT_AGENT_HOME}}/logs/evening-rollup-systemd.log
StandardError=append:{{TENANT_AGENT_HOME}}/logs/evening-rollup-systemd.log
TimeoutStartSec=300
