# Discord channel integration — environment variables
# Source these into {{TENANT_AGENT_HOME}}/.env (the discord-* scripts read from there).
#
# Get bot token from https://discord.com/developers/applications → Your App → Bot → Reset Token.
# Get channel IDs by enabling Developer Mode in Discord (User Settings → Advanced → Developer Mode),
# then right-clicking each channel → Copy Channel ID.

# Bot credentials
DISCORD_BOT_TOKEN="REPLACE_WITH_BOT_TOKEN"          # Treat like a password
DISCORD_GUILD_ID="REPLACE_WITH_GUILD_ID"            # Right-click server name → Copy Server ID

# Owner — the human who can type in #commands channel (their Discord user ID)
DISCORD_OWNER_USER_ID="REPLACE_WITH_YOUR_USER_ID"   # Right-click your own username → Copy User ID

# Channel IDs by memory type — used by discord-memory.sh post
DISCORD_CH_FACTS="REPLACE_WITH_CHANNEL_ID"           # #memory-facts
DISCORD_CH_DECISIONS="REPLACE_WITH_CHANNEL_ID"       # #memory-decisions
DISCORD_CH_RELATIONSHIPS="REPLACE_WITH_CHANNEL_ID"   # #memory-relationships
DISCORD_CH_PATTERNS="REPLACE_WITH_CHANNEL_ID"        # #memory-patterns
DISCORD_CH_COMMITMENTS="REPLACE_WITH_CHANNEL_ID"     # #memory-commitments
DISCORD_CH_PREFERENCES="REPLACE_WITH_CHANNEL_ID"     # #memory-preferences
DISCORD_CH_GOALS="REPLACE_WITH_CHANNEL_ID"           # #memory-goals
DISCORD_CH_CONTEXT="REPLACE_WITH_CHANNEL_ID"         # #memory-context

# Channel IDs for ops/event streams
DISCORD_CH_AGENT_LOG="REPLACE_WITH_CHANNEL_ID"       # #agent-log — every state change
DISCORD_CH_TASK_EVENTS="REPLACE_WITH_CHANNEL_ID"     # #task-events — per-task threads
DISCORD_CH_INTEL="REPLACE_WITH_CHANNEL_ID"           # #intel — research summaries
DISCORD_CH_COMMANDS="REPLACE_WITH_CHANNEL_ID"        # #commands — bidirectional (poll input, post output)
DISCORD_CH_DAILY_BRIEF="REPLACE_WITH_CHANNEL_ID"     # #daily-brief — morning brief + weekly digest
DISCORD_CH_GHL_ACTIVITY="REPLACE_WITH_CHANNEL_ID"    # #ghl-activity — pipeline + contact events
DISCORD_CH_GMAIL_ALERTS="REPLACE_WITH_CHANNEL_ID"    # #gmail-alerts — hot lead detections
